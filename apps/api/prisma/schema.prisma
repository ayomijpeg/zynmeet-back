generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  name           String         // Mandatory field
  passwordHash   String?
  provider       String         @default("google") // Fixes Error 3 (src/index.ts:96)
  walletBalance  Int            @default(0)
  createdAt      DateTime       @default(now())

  // Relationships (Names fixed for consistency)
  hostedRooms    Room[]         @relation("HostedBy")
  walletRecord   WalletBalance? // Fixes Error 7 (billing.service.ts:45)
  ledgerEntries  WalletLedger[] 
}

model Room {
  id        String   @id @default(uuid())
  slug      String   @unique
  hostId    String
  host      User     @relation("HostedBy", fields: [hostId], references: [id])
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model WalletBalance {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  user      User     @relation(fields: [userId], references: [id])
  updatedAt DateTime @updatedAt
}

model WalletLedger {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  type      String   
  gateway   String?  // Fixes Error 2 & 6 (index.ts and webhook.routes.ts)
  eventId   String?  @unique // Fixes Error 9 (billing.service.ts:77)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
